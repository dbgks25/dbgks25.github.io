---
layout: null
permalink: /search.json
sitemap: false
---
[
  {% for p in site.posts %}
  {
    "title": {{ p.title | jsonify }},
    "url": {{ p.url | relative_url | jsonify }},
    "type": "논문",
    "year": {{ p.date | date: "%Y" | jsonify }},
    "venue": {{ p.venue | default: "" | jsonify }},
    "authors": {{ p.authors | join: ", " | jsonify }},
    "tags": {{ p.tags | join: " " | jsonify }},
    "summary": {{ p.description | default: "" | jsonify }},
    "content": {{ p.content | strip_html | normalize_whitespace | truncate: 1500 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  {% if site.posts.size > 0 and site.projects.size > 0 %},{% endif %}
  {% for pr in site.projects %}
  {
    "title": {{ pr.title | jsonify }},
    "url": {{ pr.url | relative_url | jsonify }},
    "type": "연구과제",
    "year": {{ pr.date | date: "%Y" | jsonify }},
    "venue": {{ pr.agency | default: "" | jsonify }},
    "authors": {{ pr.role | default: "" | jsonify }},
    "tags": {{ pr.tags | join: " " | jsonify }},
    "summary": {{ pr.summary | default: "" | jsonify }},
    "content": {{ pr.content | strip_html | normalize_whitespace | truncate: 1500 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
